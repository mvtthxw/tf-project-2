{
  "name": "tf-project-2 (Terraform / EKS / Helm / PHP)",
  "image": "mcr.microsoft.com/devcontainers/base:jammy",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13"
    },
    "ghcr.io/devcontainers/features/aws-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false,
      "installDockerBuildx": true
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "1.15.2"
    },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "kubectl": "latest",
      "minikube": "none"
    },
    "ghcr.io/devcontainers/features/php:1": {
      "version": "8.3",
      "installComposer": true
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "hashicorp.hcl",
        "redhat.vscode-yaml",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-containers",
        "amazonwebservices.aws-toolkit-vscode",
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "EditorConfig.editorconfig",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[terraform]": {
          "editor.defaultFormatter": "hashicorp.terraform",
          "editor.formatOnSave": true
        },
        "[terraform-vars]": {
          "editor.defaultFormatter": "hashicorp.terraform"
        },
        "[hcl]": {
          "editor.defaultFormatter": "hashicorp.terraform"
        },
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "yaml.schemas": {
          "https://json.schemastore.org/helmfile.json": [
            "helmfile.yaml",
            "helmfile.yml"
          ],
          "kubernetes": [
            "**/charts/**/templates/**/*.yaml",
            "**/charts/**/templates/**/*.yml"
          ]
        },
        "files.associations": {
          "*.tmpl.hcl": "terraform"
        }
      }
    }
  },

  "forwardPorts": [8081, 8082],
  "portsAttributes": {
    "8081": {
      "label": "app-managed (PHP)",
      "onAutoForward": "notify"
    },
    "8082": {
      "label": "app-fargate (PHP)",
      "onAutoForward": "notify"
    }
  },

  "runArgs": [
    "--env-file=${localEnv:HOME}/Documents/.env"
  ],

  "mounts": [
    "source=cursor-state-tf-project-2,target=/home/vscode/.cursor,type=volume"
  ],

  "postCreateCommand": "terraform -version && kubectl version --client=true --output=yaml | head -n 5 && helm version && php -v && docker --version",
  "remoteUser": "vscode"
}
